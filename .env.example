# =========================
# Travel AI Environment Vars
# =========================

# OpenAI API Key (server-side only; no quotes needed)
OPENAI_API_KEY=your_openai_api_key_here

# Model for /api/recommend (default: gpt-4.1-nano)
OPENAI_MODEL=gpt-4.1-nano

# Rate limit for /api/recommend (default: 10 requests per 60 seconds per IP)
RECOMMEND_RATE_LIMIT_MAX=10
RECOMMEND_RATE_LIMIT_WINDOW_MS=60000

# App Config
NEXT_PUBLIC_APP_NAME=Travel AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
